{
  "manifest_version": 3,
  "name": "MailMiner",
  "version": "1.7.4",
  "description": "MailMiner — extract, validate, and export emails from sheets, paste, and OCR.",
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "host_permissions": [
    "https://validator-api.fsgarage.in/*",
    "https://docs.google.com/*",
    "https://hackathon-ocr-worker-3.dygkh7.easypanel.host/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "927778397565-u9t68i0vf8l7hj4pt0qk9qaif7vakgj7.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
